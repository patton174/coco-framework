<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>io.github.coco.compatibility.consumer</groupId>
    <artifactId>coco-feature-api-consumer</artifactId>
    <version>1.0.0-SNAPSHOT</version>

    <properties>
        <coco.version>2.0.1</coco.version>
        <maven.compiler.release>17</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>io.github.patton174</groupId>
                <artifactId>coco-dependencies</artifactId>
                <version>${coco.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-test</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <profiles>
        <profile>
            <id>canonical</id>
            <dependencies>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-web</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-mybatis-plus</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-tenant</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-data-permission</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-audit</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-security</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-openapi</artifactId>
                </dependency>
            </dependencies>
        </profile>
        <profile>
            <id>aliases</id>
            <dependencies>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-web</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-mybatis-plus</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-tenant</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-data-permission</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-audit</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-security</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-openapi</artifactId>
                </dependency>
            </dependencies>
        </profile>
        <profile>
            <id>mixed</id>
            <dependencies>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-web</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-web</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-mybatis-plus</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-mybatis-plus</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-tenant</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-tenant</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-data-permission</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-data-permission</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-audit</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-audit</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-security</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-security</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-openapi</artifactId>
                </dependency>
                <dependency>
                    <groupId>io.github.patton174</groupId>
                    <artifactId>coco-feature-openapi</artifactId>
                </dependency>
            </dependencies>
        </profile>
    </profiles>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.15.0</version>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>3.9.0</version>
            </plugin>
        </plugins>
    </build>
</project>
