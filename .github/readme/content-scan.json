{
  "schemaVersion": 1,
  "include": {
    "exact": [
      "AGENTS.md",
      "pom.xml"
    ],
    "prefixes": [
      "coco-",
      "coco-support/coco-document/"
    ],
    "suffixes": [
      "/pom.xml"
    ]
  },
  "exclude": {
    "exact": [
      "README.md",
      "README_CN.md",
      ".github/workflows/readme-maintenance.yml"
    ],
    "prefixes": [
      ".github/readme/"
    ],
    "suffixes": []
  }
}
