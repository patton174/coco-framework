        "README.md",
        "README_CN.md",
        "SECURITY.md",
        "SUPPORT.md",
        "coco-support/coco-document/release.md",
        "coco-support/coco-document/superpowers/specs/2026-07-11-agent-governance-automation.md"
      ],
      "spec_paths": [
        "coco-support/coco-document/superpowers/specs/2026-07-11-agent-governance-automation.md"
      ]
    },
    {
      "path_globs": [
