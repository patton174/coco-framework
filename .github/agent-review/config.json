{
  "version": 1,
  "gate_name": "Agent jury gate",
  "managed_comment_marker": "<!-- agent-jury:v1 -->",
  "deferred_bot_authors": [
    {
      "login": "dependabot[bot]",
      "id": 49699333
    }
  ],
  "protected_policy_paths": [
    "AGENTS.md",
    ".github/agent-review/policy.md"
  ],
  "roles": {
    "specialists": [
      {
        "id": "architecture-api",
        "prompt_path": ".github/agent-review/prompts/specialist.md",
        "lens": "Framework positioning, module dependency direction, starter and auto-configuration boundaries, public API and SPI stability, compatibility, and build-time versus runtime composition.",
        "include_pr_intent": true,
        "intent_isolation": {
          "enabled": false,
          "excluded_context_sections": [],
          "retain_protected_policy": true
        }
      },
      {
        "id": "correctness",
        "prompt_path": ".github/agent-review/prompts/specialist.md",
        "lens": "Logic, concurrency, lifecycle and resource handling, exception propagation, feature planning, and consistency between build-time and runtime behavior.",
        "include_pr_intent": true,
        "intent_isolation": {
          "enabled": false,
          "excluded_context_sections": [],
          "retain_protected_policy": true
        }
      },
      {
        "id": "security-isolation",
        "prompt_path": ".github/agent-review/prompts/specialist.md",
        "lens": "Workflow and secret boundaries, request security, tenant and data-permission isolation, SQL safety, encryption, signatures, and replay protection.",
        "include_pr_intent": true,
        "intent_isolation": {
          "enabled": false,
          "excluded_context_sections": [],
          "retain_protected_policy": true
        }
      },
      {
        "id": "tests-release",
        "prompt_path": ".github/agent-review/prompts/specialist.md",
        "lens": "Test adequacy, negative and regression coverage, cross-platform behavior, Maven plugin behavior, package pruning, release safety, and operational regressions.",
        "include_pr_intent": true,
        "intent_isolation": {
          "enabled": false,
          "excluded_context_sections": [],
          "retain_protected_policy": true
        }
      },
      {
        "id": "robustness-blind",
        "prompt_path": ".github/agent-review/prompts/specialist.md",
        "lens": "Input drift, silent loss, scale assumptions, observability gaps, partial failure, and unconstrained invariants without relying on the author's stated intent.",
        "include_pr_intent": false,
        "intent_isolation": {
          "enabled": true,
          "excluded_context_sections": [
            "pr_intent"
          ],
          "excluded_context_fields": [
            "pull_request.title",
            "pull_request.body",
            "commit_messages",
            "by_design_explanations"
          ],
          "retain_protected_policy": true
        }
      }
    ],
    "verifiers": [
      {
        "id": "evidence-verifier",
        "prompt_path": ".github/agent-review/prompts/cross-review.md",
        "lens": "Verify each P0 through P3 finding against concrete code, line anchors, execution paths, triggers, and observable behavior. Distinguish false claims from missing context."
      },
      {
        "id": "policy-skeptic",
        "prompt_path": ".github/agent-review/prompts/cross-review.md",
        "lens": "Verify each P0 through P3 finding against protected project policy, explicit non-goals, accepted governance choices, public contracts, and severity criteria."
      }
    ],
    "chair": {
      "id": "chair",
      "prompt_path": ".github/agent-review/prompts/chair.md",
      "lens": "Deduplicate and attribute findings, preserve verifier disagreement, and organize the deterministic result without creating or reclassifying blockers."
    }
  },
  "context_budget": {
    "unit": "unicode_characters",
    "pr_diff_hard_limit": 180000,
    "specialist_total_limit": 384000,
    "protected_policy_and_specs_limit": 48000,
    "pr_intent_limit": 8000,
    "patch_limit": 180000,
    "code_context_total_limit": 60000,
    "code_context_per_file_limit": 4000,
    "full_changed_file_limit": 12000,
    "code_context_file_limit": 24,
    "remainder_sources": [
      "full_changed_files",
      "base_comparisons",
      "related_tests",
      "module_poms",
      "auto_configuration_imports",
      "configuration_metadata"
    ],
    "always_include": [
      "output_schema",
      "current_task",
      "base_sha",
      "head_sha",
      "context_sha256",
      "context_omissions"
    ],
    "overflow_behavior": {
      "pr_diff_hard_limit": "fail",
      "section_limit": "prioritize_then_record_omission",
      "specialist_total_limit": "fail_if_required_context_cannot_fit"
    }
  },
  "output_limits": {
    "specialist_findings": 10,
    "specialist_questions": 5,
    "specialist_context_gaps": 10,
    "specialist_tokens": 8192,
    "verifier_tokens": 8192,
    "chair_tokens": 8192
  },
  "spec_resolution": {
    "revision": "base_sha",
    "matching": "all_matching_entries",
    "deduplicate": true
  },
  "spec_path_mappings": [
    {
      "path_globs": [
        ".github/agent-review/**",
        ".github/workflows/*agent-review*.yml",
        ".github/workflows/agent-review.yml",
        ".github/workflows/agent-issue-gate.yml",
        ".github/scripts/agent_review.py",
        ".github/scripts/agent_issue_gate.py",
        ".github/scripts/test_agent_review.py"
      ],
      "spec_paths": [
        "coco-support/coco-document/superpowers/specs/2026-07-10-multi-agent-review-jury.md"
      ]
    },
    {
      "path_globs": [
        ".github/**",
        "AGENTS.md",
        "CODE_OF_CONDUCT.md",
        "CONTRIBUTING.md",
        "GOVERNANCE.md",
