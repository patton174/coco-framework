        "coco-support/coco-tools/**",
        "docs/architecture/module-layout.md",
        "coco-support/coco-document/architecture/module-layout.md"
      ],
      "spec_paths": [
        "coco-support/coco-document/architecture/module-layout.md"
      ]
    },
    {
      "path_globs": [
        "coco-api/**",
        "coco-foundation/coco-api/**",
