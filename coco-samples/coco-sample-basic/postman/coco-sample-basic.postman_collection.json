                  "pm.test(\"HTTP 409\", function () {",
                  "    pm.response.to.have.status(409);",
                  "});",
                  "",
                  "pm.test(\"返回英文库存不足错误\", function () {",
                  "    pm.expect(body.success).to.eql(false);",
                  "    pm.expect(body.code).to.eql(1004);",
                  "    pm.expect(pm.response.headers.get(\"X-Trace-Id\")).to.eql(\"postman-stock-error-en\");",
                  "    pm.expect(body).to.not.have.property(\"traceId\");",
                  "    pm.expect(body).to.not.have.property(\"path\");",
                  "    pm.expect(body.message).to.include(\"Product COCO-STARTER has insufficient stock\");",
                  "    pm.expect(body.message).to.include(\"requested quantity 99\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "订单不存在 zh-CN",
